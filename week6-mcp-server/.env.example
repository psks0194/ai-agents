# IntellAIgent Content Ops — environment reference.
#
# This documents the vars THIS server reads, so you know what to keep in the
# real .env. But note: config.py loads the SHARED repo-root .env
# (../.env from here), not a week6-local file — put real values there.
# Copy the repo-root template: `cp ../.env.example ../.env` and fill it in.

# Required — only the draft_thread tool uses it (Anthropic API call).
# fetch_feed, check_voice, and generate_card_spec run without a key.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional — model used by draft_thread. Defaults to claude-haiku-4-5.
DEFAULT_MODEL=claude-haiku-4-5
